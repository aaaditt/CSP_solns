EMAIL_ADDRESS=me@example.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
IMAP_HOST=imap.gmail.com

# Get your Gemini API key from https://aistudio.google.com/apikey
# Use a SEPARATE key from task2/task3 - those already share one GOOGLE_API_KEY
# capped at ~20 requests/day on the free tier, and this project makes one
# classification call per new email per sync.
GOOGLE_API_KEY=your-gemini-api-key

SYNC_MAX_EMAILS=100
INCLUDE_BODY_SNIPPET=true
